# ⚠️ DO NOT EDIT THIS FILE - It's a template only!
# Copy to .env.local and fill in your actual values
# NEVER commit .env.local to git

# ========================
# PUBLIC (Safe in browser)
# ========================
VITE_FIREBASE_API_KEY=your_public_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_web_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-YOUR_MEASUREMENT_ID

# Optional - Override API base URL (defaults to /api)
VITE_API_URL=http://localhost:3000/api

# ========================
# PRIVATE (Backend only)
# ========================
# NEVER expose these to browser
# NEVER commit these to git
# Only set in Vercel Dashboard for production

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# For frontend to know backend URL in production
FRONTEND_URL=https://yourdomain.com
